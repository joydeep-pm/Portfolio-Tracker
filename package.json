{
  "name": "portfolio-tracker",
  "version": "1.0.0",
  "description": "Interactive thematic engine prototype that models: - 2,486 stocks - 26 core thematic heads - 175 micro-clusters - momentum windows: `1D`, `1W`, `1M`, `6M`, `YTD`",
  "main": "adapterCore.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "node --test tests/*.test.js",
    "harvest:macro": "node scripts/harvest-macro-news.js --format table --per-source 40 --limit 25",
    "analyze:macro-context": "node scripts/macro-context-analyze.js --format table --limit 30"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joydeep-pm/Portfolio-Tracker.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/joydeep-pm/Portfolio-Tracker/issues"
  },
  "homepage": "https://github.com/joydeep-pm/Portfolio-Tracker#readme",
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "typescript": "^5.9.3"
  }
}
