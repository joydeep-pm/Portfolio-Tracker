# Portfolio Tracker - environment template
# Copy to `.env.local` for local development and keep real secrets out of git.

# Core runtime
BROKER_PROVIDER=kite-direct
MAX_ORDER_VALUE_INR=200000
ENABLE_LIVE_TRADING=false

# Zerodha Kite integration
KITE_API_KEY=
KITE_API_SECRET=
KITE_REDIRECT_URL=http://127.0.0.1:4173/api/zerodha/callback
KITE_ACCESS_TOKEN=

# Snapshot persistence (optional; in-memory fallback when missing)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# PKScreener live mode (optional)
ENABLE_PKSCREENER_LIVE=false
PKSCREENER_CMD=

# Optional Angel readiness probe vars
ANGEL_API_KEY=
ANGEL_CLIENT_CODE=
ANGEL_PIN=
ANGEL_TOTP_SECRET=
